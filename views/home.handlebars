
<main class="hero-wrapper">
  <img
    class="hero-image"
    src="https://realestateexposures.com/wp-content/uploads/2022/10/New-York-City-scaled.jpg"
    alt="New York City skyline"
  />

  <h1 class="hero-title">Discover NYC Events &amp; Communities</h1>
  <p class="hero-subtitle">Find events, meet people, and explore NYC together</p>

  <section class="search-panel">
    <div class="dropdown">
      <button class="dropdown-btn" type="button">
        <span>Borough</span>
        <span>▼</span>
      </button>
      <div class="dropdown-menu">
        <div>Manhattan</div>
        <div>Brooklyn</div>
        <div>Queens</div>
        <div>Bronx</div>
        <div>Staten Island</div>
      </div>
    </div>

    <div class="dropdown">
      <button class="dropdown-btn" type="button">
        <span>Event Date</span>
        <span>▼</span>
      </button>
      <div class="dropdown-menu date-menu">
        <div>Today</div>
        <div>Tomorrow</div>
        <div>This Week</div>
        <div>This Weekend</div>
        <div class="date-picker-row">
          <label for="manual-date">Pick a date</label>
          <input type="date" id="manual-date" />
        </div>
      </div>
    </div>

    <div class="dropdown">
      <button class="dropdown-btn" type="button">
        <span>Event Time</span>
        <span>▼</span>
      </button>
      <div class="dropdown-menu">
        <div>Morning (6:00 AM – 11:59 AM)</div>
        <div>Afternoon (12:00 PM – 4:59 PM)</div>
        <div>Evening (5:00 PM – 8:59 PM)</div>
        <div>Night (9:00 PM – 5:59 AM)</div>
      </div>
    </div>
  </section>
</main>