<main class="hero-wrapper">
  <section class="hero-panel">
    <div class="hero-copy">
      <h1 class="hero-title">Discover NYC Events &amp; Communities</h1>
      <p class="hero-subtitle">Find local events, meet new people, and explore the city with your community.</p>
    </div>

    <img
      class="hero-image"
      src="https://realestateexposures.com/wp-content/uploads/2022/10/New-York-City-scaled.jpg"
      alt="New York City skyline"
    >
  </section>

  <section class="search-shell" aria-label="Find events">
    <form id="home-search-form" class="search-panel" action="/events/search" method="GET" novalidate>
      <div class="search-field">
        <label for="borough">Borough</label>
        <select id="borough" name="borough">
          <option value="">Any borough</option>
          <option value="Manhattan">Manhattan</option>
          <option value="Brooklyn">Brooklyn</option>
          <option value="Queens">Queens</option>
          <option value="Bronx">Bronx</option>
          <option value="Staten Island">Staten Island</option>
        </select>
      </div>

      <div class="search-field">
        <label for="category">Category</label>
        <select id="category" name="category">
          <option value="">Any category</option>
          <option value="Academic/Out of School time">Academic/Out of School time</option>
          <option value="Arts/Culture">Arts/Culture</option>
          <option value="Family Festival">Family Festival</option>
          <option value="Fitness">Fitness</option>
          <option value="Mobile Unit">Mobile Unit</option>
          <option value="Performance">Performance</option>
          <option value="Sport">Sport</option>
        </select>
      </div>

      <div class="search-field">
        <label for="date">Date</label>
        <input id="date" name="date" type="date">
      </div>

      <div class="search-field">
        <label for="time">Time</label>
        <select id="time" name="time">
          <option value="">Any time</option>
          <option value="morning">Morning</option>
          <option value="afternoon">Afternoon</option>
          <option value="evening">Evening</option>
          <option value="night">Night</option>
        </select>
      </div>

      <button class="search-btn primary-btn" type="submit">Search</button>
      <p id="search-error" class="search-panel-error field-error" aria-live="polite"></p>
    </form>
  </section>
</main>
