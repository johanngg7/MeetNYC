<article class="event-card" data-id="{{_id}}">
  <div class="event-image-wrap loading">
    {{#if image}}
      <img
        src="{{image}}"
        alt="{{title}}"
        class="event-image"
        onerror="this.onerror=null;this.src='https://azure-na-images.contentstack.com/v3/assets/blt738d1897c3c93fa6/bltfa5d0fb785639f6f/685040c8f7cdb0fdfa0e6392/MG_1_1_New_York_City_1.webp';"
      >
    {{else}}
      <img
        src="https://azure-na-images.contentstack.com/v3/assets/blt738d1897c3c93fa6/bltfa5d0fb785639f6f/685040c8f7cdb0fdfa0e6392/MG_1_1_New_York_City_1.webp"
        alt="{{title}}"
        class="event-image"
      >
    {{/if}}

    <span class="badge">{{borough}}</span>
  </div>

  <div class="event-card-body">
    <h3 class="event-title">{{title}}</h3>
    <p class="event-meta">{{#if displayCategory}}{{displayCategory}}{{else}}{{category}}{{/if}} • {{startDate}}</p>

    {{#if locationText}}
      <p class="event-location">{{locationText}}</p>
    {{else}}
      {{#if location}}
        <p class="event-location">{{location}}</p>
      {{/if}}
    {{/if}}

    <div class="event-card-actions">
      <a href="/events/{{_id}}" class="primary-btn">View</a>
      {{#if mapUrl}}
        <a href="{{mapUrl}}" target="_blank" rel="noopener" class="secondary-btn">Map</a>
      {{/if}}

      {{#if ../isLoggedIn}}
        {{#if (hasId ../savedEventIds _id)}}
          <button class="secondary-btn save-btn saved" type="button" data-id="{{_id}}">
            Unsave Event
          </button>
        {{else}}
          <button class="secondary-btn save-btn" type="button" data-id="{{_id}}">
            Save Event
          </button>
        {{/if}}
      {{else}}
        <a href="/login" class="secondary-btn">Save Event</a>
      {{/if}}
    </div>
  </div>
</article>
