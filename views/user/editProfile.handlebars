<div class="create-event-page">
  <div class="create-event-card">

    <h1>Edit Profile</h1>

    {{#if error}}
      <p id="error">{{error}}</p>
    {{/if}}

    <form id="profile-edit-form" name="profile-edit-form" action="/user/profile/edit" method="POST" class="event-form" novalidate>

      <div class="form-group">
        <label for="handle">Handle *</label>
        <input type="text" id="handle" name="handle" value="{{form.handle}}" required />
      </div>

      <div class="form-group">
        <label for="firstName">First Name *</label>
        <input type="text" id="firstName" name="firstName" value="{{form.firstName}}" required />
      </div>

      <div class="form-group">
        <label for="lastName">Last Name *</label>
        <input type="text" id="lastName" name="lastName" value="{{form.lastName}}" required />
      </div>

      <div class="form-group">
        <label for="email">Email *</label>
        <input type="email" id="email" name="email" value="{{form.email}}" required />
      </div>

      <div class="form-group">
        <label for="borough">Borough *</label>
        <select id="borough" name="borough" required>
          <option value="">Select borough</option>
          <option value="Manhattan" {{#if (eq form.borough "Manhattan")}}selected{{/if}}>Manhattan</option>
          <option value="Brooklyn" {{#if (eq form.borough "Brooklyn")}}selected{{/if}}>Brooklyn</option>
          <option value="Queens" {{#if (eq form.borough "Queens")}}selected{{/if}}>Queens</option>
          <option value="Bronx" {{#if (eq form.borough "Bronx")}}selected{{/if}}>Bronx</option>
          <option value="Staten Island" {{#if (eq form.borough "Staten Island")}}selected{{/if}}>Staten Island</option>
        </select>
      </div>

      <div class="form-group">
        <label for="password">New Password</label>
        <input type="password" id="password" name="password" />
      </div>

      <div class="form-group">
        <label for="confirmPassword">Confirm New Password</label>
        <input type="password" id="confirmPassword" name="confirmPassword" />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Save Changes</button>
        <a href="/user/profile" class="secondary-btn">Cancel</a>
      </div>

    </form>
  </div>
</div>
