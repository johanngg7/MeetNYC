<section class="profile-page">
  <div class="profile-container">

    <div class="profile-header">
      <h1>{{user.firstName}} {{user.lastName}}</h1>
      <p class="profile-subtitle">@{{user.handle}} • {{user.borough}}</p>

      <div class="form-actions">
        <a href="/user/profile/edit" class="btn-primary btn-link">Edit Profile</a>
      </div>

      {{#unless isAdmin}}
        <form action="/user/profile/delete" method="POST" class="event-form" novalidate>
          <div class="form-actions">
            <button type="submit" class="danger-btn">Delete Account</button>
          </div>
        </form>
      {{/unless}}
    </div>

    <div class="profile-section">
      <h2>Events Created</h2>

      {{#if createdEvents.length}}
        <div class="event-grid">
          {{#each createdEvents}}
            {{> eventCard}}
          {{/each}}
        </div>
      {{else}}
        <p class="empty-text">Haven't created any events yet.</p>
      {{/if}}
    </div>

    <div class="profile-section">
      <h2>Events Attending</h2>

      {{#if rsvpedEvents.length}}
        <div class="event-grid">
          {{#each rsvpedEvents}}
            {{> eventCard}}
          {{/each}}
        </div>
      {{else}}
        <p class="empty-text">Haven't RSVP'd to any events yet.</p>
      {{/if}}
    </div>

    <div class="profile-section">
      <h2>Saved Events</h2>

      {{#if savedEvents.length}}
        <div class="event-grid">
          {{#each savedEvents}}
            {{> eventCard}}
          {{/each}}
        </div>
      {{else}}
        <p class="empty-text">No saved events yet.</p>
      {{/if}}
    </div>

  </div>
</section>
