<div class="event-details-page">
  <div class="event-details-card">

    <div class="event-main">
      {{#if event.image}}
        <img src="{{event.image}}" alt="{{event.title}}" class="event-details-image">
      {{/if}}

      <h1>{{event.title}}</h1>
      <p class="subtitle">Discover and join this NYC event</p>

      <div class="event-info">
        <p><strong>Category:</strong> {{#if event.displayCategory}}{{event.displayCategory}}{{else}}{{event.category}}{{/if}}</p>
        <p><strong>Borough:</strong> {{event.borough}}</p>
        {{#if event.locationText}}
          <p><strong>Location:</strong> {{event.locationText}}</p>
          {{#if event.mapUrl}}
            <p><a href="{{event.mapUrl}}" target="_blank" rel="noopener" class="map-link">Open in Maps</a></p>
          {{/if}}
        {{/if}}
        <p><strong>Date:</strong> {{event.startDate}}</p>
        <p><strong>Start Time:</strong> {{event.startTime}}</p>
        <p><strong>End Time:</strong> {{event.endTime}}</p>

        {{#if event.description}}
          <p><strong>Description:</strong> {{event.description}}</p>
        {{/if}}

        {{#if event.creator}}
          <p><strong>Created by:</strong> {{event.creator}}</p>
        {{/if}}
      </div>
    </div>

    <div class="event-side-panel"
         data-event-id="{{event._id}}"
         data-event-title="{{event.title}}"
         data-event-location="{{#if event.locationText}}{{event.locationText}}{{else}}{{event.borough}}{{/if}}"
         data-event-date="{{event.startDate}}"
         data-event-start="{{event.startTime}}"
         data-event-end="{{event.endTime}}"
         data-event-description="{{event.description}}">
      <h2>Event Actions</h2>

      <p><strong>Attending:</strong> <span id="attendeeCount">{{attendeeCount}}</span>{{#if event.attendanceCap}} / {{event.attendanceCap}}{{/if}}</p>

      {{#if event.attendanceCap}}
        <p class="spots-left {{#if event.isFull}}is-full{{/if}}">
          <span id="spotsLeftText">
            {{#if event.isFull}}Event is full{{else}}{{event.spotsLeft}} spot{{#unless (eq event.spotsLeft 1)}}s{{/unless}} left{{/if}}
          </span>
        </p>
      {{/if}}

      <p><strong>Average Rating:</strong> <span id="averageRating">{{#if event.averageRating}}{{event.averageRating}} / 5{{else}}No reviews{{/if}}</span></p>

      <div class="form-actions">
        <button type="button" id="shareBtn" class="secondary-btn detail-action share-btn">Share Event</button>
      </div>

      <div class="form-actions">
        <button type="button" id="calendarBtn" class="secondary-btn detail-action calendar-btn">Add to Calendar</button>
      </div>

      {{#if isLoggedIn}}
        <form id="rsvpForm" action="/events/{{event._id}}/rsvp" method="POST" class="event-form" data-id="{{event._id}}" novalidate>
          <div class="form-actions">
            <button id="rsvpBtn" type="submit" class="btn-primary" {{#if event.isFull}}{{#unless isAttending}}disabled{{/unless}}{{/if}}>
              {{#if isAttending}}Cancel RSVP{{else}}{{#if event.isFull}}Event Full{{else}}RSVP{{/if}}{{/if}}
            </button>
          </div>
          <p id="rsvpMsg" class="form-msg"></p>
        </form>

        <div class="form-actions">
          <button type="button" class="secondary-btn detail-action save-btn{{#if isSaved}} saved{{/if}}" data-id="{{event._id}}">
            {{#if isSaved}}Unsave Event{{else}}Save Event{{/if}}
          </button>
        </div>

        <div class="form-actions">
          <button type="button" class="report-btn detail-action report-event-btn" data-id="{{event._id}}">Report Event</button>
        </div>
      {{/if}}

      {{#if isOwner}}
        <div class="form-actions">
          <a href="/events/{{event._id}}/edit" class="secondary-btn detail-action btn-link">Edit Event</a>
        </div>

        <form action="/events/{{event._id}}/delete" method="POST" class="event-form" novalidate>
          <div class="form-actions">
            <button type="submit" class="danger-btn detail-action">Delete Event</button>
          </div>
        </form>
      {{/if}}

      {{#if isAdmin}}
        <div class="form-actions">
          <button type="button" class="report-btn detail-action admin-flag-btn" data-id="{{event._id}}">Flag Event</button>
        </div>
        <div class="form-actions">
          <button type="button" class="danger-btn detail-action admin-remove-btn" data-id="{{event._id}}">Remove Event</button>
        </div>
      {{/if}}
    </div>

  </div>

  <div class="event-comments-card">
    <h2>Comments</h2>

    {{#if isLoggedIn}}
      <form id="commentForm" action="/events/{{event._id}}/comments" method="POST" class="event-form" data-id="{{event._id}}" novalidate>
        <div class="form-group">
          <label for="comment">Leave a Comment</label>
          <textarea id="comment" name="comment" rows="4" placeholder="Write your comment here..."></textarea>
        </div>

        <div class="form-actions">
          <button type="submit" class="btn-primary">Post Comment</button>
        </div>
        <p id="commentMsg" class="form-msg"></p>
      </form>
    {{/if}}

    <div id="commentList" class="comment-list">
      {{#each event.comments}}
        <div class="comment-card" data-id="{{this._id}}">
          <p><strong>{{this.userName}}</strong></p>
          <p>{{this.text}}</p>

          {{#if ../isAdmin}}
            <button type="button" class="report-btn compact-btn admin-flag-comment-btn" data-cid="{{this._id}}" data-eid="{{../event._id}}">Flag Comment</button>
            <button type="button" class="danger-btn compact-btn delete-comment-btn" data-cid="{{this._id}}" data-eid="{{../event._id}}">Remove Comment</button>
          {{else}}
            {{#if ../isLoggedIn}}
              <button type="button" class="report-btn compact-btn report-comment-btn" data-cid="{{this._id}}" data-eid="{{../event._id}}">Report Comment</button>
            {{/if}}
          {{/if}}
        </div>
      {{/each}}
    </div>
    {{#unless event.comments.length}}
      <p id="commentEmpty">No comments yet.</p>
    {{/unless}}
  </div>

  <div class="event-reviews-card">
    <h2>Reviews</h2>

    {{#if eventEnded}}
      {{#if isLoggedIn}}
        <form id="reviewForm" action="/events/{{event._id}}/reviews" method="POST" class="event-form" data-id="{{event._id}}" novalidate>
          <div class="form-group">
            <label for="rating">Rating</label>
            <select id="rating" name="rating" required>
              <option value="">Select rating</option>
              <option value="1">1</option>
              <option value="2">2</option>
              <option value="3">3</option>
              <option value="4">4</option>
              <option value="5">5</option>
            </select>
          </div>

          <div class="form-group">
            <label for="review">Review</label>
            <textarea id="review" name="review" rows="4" placeholder="Write your review here..."></textarea>
          </div>

          <div class="form-actions">
            <button type="submit" class="btn-primary">Submit Review</button>
          </div>
          <p id="reviewMsg" class="form-msg"></p>
        </form>
      {{/if}}
    {{else}}
      <p class="empty-text">Reviews open after the event ends.</p>
    {{/if}}

    <div id="reviewList" class="review-list">
      {{#each event.reviews}}
        <div class="review-card" data-id="{{this._id}}">
          <p><strong>{{this.userName}}</strong> - {{this.rating}}/5</p>
          <p>{{this.text}}</p>

          {{#if ../isAdmin}}
            <button type="button" class="danger-btn compact-btn delete-review-btn" data-rid="{{this._id}}" data-eid="{{../event._id}}">Remove Review</button>
          {{/if}}
        </div>
      {{/each}}
    </div>
    {{#unless event.reviews.length}}
      <p id="reviewEmpty">No reviews yet.</p>
    {{/unless}}
  </div>

  {{#if similarEvents.length}}
    <div class="similar-events-card">
      <h2>Similar Events</h2>
      <div class="event-grid similar-events-grid">
        {{#each similarEvents}}
          {{> eventCard}}
        {{/each}}
      </div>
    </div>
  {{/if}}
</div>
