<section class="section-block">
  <h1>Admin Dashboard</h1>

  {{#if error}}
    <p class="error-text">{{error}}</p>
  {{/if}}

  <div class="details-content-card">
    <h2>Flagged Events</h2>

    {{#if flaggedEvents.length}}
      {{#each flaggedEvents}}
        <div class="admin-item" data-event-id="{{_id}}">
          <p><strong><a href="/events/{{_id}}">{{title}}</a></strong> — {{borough}}, {{startDate}}</p>

          <div class="admin-actions">
            <button class="secondary-btn admin-unflag-event" data-id="{{_id}}">Unflag</button>
            <button class="danger-btn admin-remove-event" data-id="{{_id}}">Remove</button>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p class="empty-text">No flagged events</p>
    {{/if}}
  </div>

  <div class="details-content-card">
    <h2>Flagged Comments</h2>

    {{#if flaggedComments.length}}
      {{#each flaggedComments}}
        <div class="admin-item" data-comment-id="{{_id}}">
          <p><strong>{{userName}}</strong> on <a href="/events/{{eventId}}">{{eventTitle}}</a></p>
          <p>{{text}}</p>

          <div class="admin-actions">
            <button class="secondary-btn admin-unflag-comment" data-event-id="{{eventId}}" data-comment-id="{{_id}}">Unflag</button>
            <button class="danger-btn admin-delete-comment" data-event-id="{{eventId}}" data-comment-id="{{_id}}">Delete</button>
          </div>
        </div>
      {{/each}}
    {{else}}
      <p class="empty-text">No flagged comments</p>
    {{/if}}
  </div>

  <div class="details-content-card">
    <h2>Users</h2>

    {{#if users.length}}
      {{#each users}}
        <div class="admin-item" data-user-id="{{_id}}">
          <p><strong>{{firstName}} {{lastName}}</strong> — @{{handle}} — {{email}} — {{#if isAdmin}}Admin{{else}}User{{/if}}</p>

          {{#unless isSelf}}
            <div class="admin-actions">
              <button class="secondary-btn admin-toggle-admin" data-id="{{_id}}">
                {{#if isAdmin}}Revoke Admin{{else}}Make Admin{{/if}}
              </button>
            </div>
          {{/unless}}
        </div>
      {{/each}}
    {{else}}
      <p class="empty-text">No users found</p>
    {{/if}}
  </div>

</section>
